{
  "schemaVersion": 1,
  "id": "blockbreakmodifier",
  "version": "${version}",
  "name": "BlockBreakModifier",
  "description": "Fully customizable per-world block-break tool and speed overrides via YAML config. No restart needed.",
  "authors": [
    "ELITE Studios"
  ],
  "contact": {
    "homepage": "https://plugincenter.store",
    "sources": "https://github.com/meyoxyt/Block-Break-Modifier"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.blockbreakmodifier.BlockBreakModifier"
    ],
    "client": [
      "com.blockbreakmodifier.client.BlockBreakModifierClient"
    ]
  },
  "mixins": [
    "blockbreakmodifier.mixins.json",
    {
      "config": "blockbreakmodifier.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.21"
  }
}
